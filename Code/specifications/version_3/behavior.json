{
    "behaviors": [
        {
            "id": "CameraFollow",
            "event": "OnCondition",
            "actors": ["player"],
            "precondition": { "runAlgorithm": "AlwaysTrue" },
            "action": { "runAlgorithm": "UpdateCameraPosition" }
        },
        {
            "id": "SpawnEncounter",
            "event": "OnCondition",
            "actors": ["player"],
            "precondition": { "runAlgorithm": "IsPlayerMovingInGrass" },
            "action": { "runAlgorithm": "TriggerRandomEncounter" }
        },
        {
            "id": "ThrowPokeball",
            "event": "OnCondition",
            "actors": ["pokeball"],
            "precondition": {
                "all": [
                    { "equals": ["Self.state", "ready"] },
                    { "runAlgorithm": "IsThrowKeyPressed" }
                ]
            },
            "action": { "runAlgorithm": "ThrowPokeball" },
            "postcondition": { "equals": ["Self.state", "thrown"] }
        },
        {
            "id": "CaptureCheck",
            "event": "OnCondition",
            "actors": ["pokeball"],
            "precondition": {
                "all": [
                    { "equals": ["Self.state", "thrown"] },
                    { "runAlgorithm": "DidPokeballHitMonster" }
                ]
            },
            "action": { "runAlgorithm": "ResolveCapture" }
        }
    ]
}